# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/
/.playwright-cli/

# local extraction environment and private evidence
/.venv/
/etc/
/data/*.raw.json
/data/*.raw.csv
/data/firestore-products.json
/public/data/products.json
/data/products.json
/data/catalog.csv
/data/enrichment-queue.json
/data/enrichment-queue.csv
/data/gpt-pro-official-review-queue.csv
/public/data/catalog.csv
/public/data/enrichment-queue.json
/public/data/enrichment-queue.csv

# collected source records stay local; only aggregate summaries are versioned
/data/kpic-details-part-[123].json
/data/kpic-image-matches.json
/data/secondary-image-matches.json
/data/secondary-image-part-[123].json
/data/naver-image-part-[123].json
/data/image-manual-review-part-[123].json
/data/official-product-details.json
/data/product-official-matches.json

# Python bytecode
__pycache__/
*.py[cod]
