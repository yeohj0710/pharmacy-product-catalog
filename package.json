{
  "name": "pharmacy-product-catalog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "catalog:text-review": "python scripts/build_catalog_text_corrections.py",
    "catalog:text:normalize": "python scripts/normalize_catalog_content.py",
    "catalog:text:check": "python scripts/normalize_catalog_content.py --check",
    "catalog:text:audit": "python scripts/audit_catalog_text.py",
    "catalog:portable:export": "python scripts/export_portable_catalog.py",
    "catalog:portable:check": "python scripts/export_portable_catalog.py --check",
    "catalog:correct": "python scripts/apply_catalog_text_corrections.py",
    "catalog:correct:check": "python scripts/apply_catalog_text_corrections.py --check",
    "catalog:sync": "npm run catalog:correct:check && npm run catalog:text:check && npm run catalog:text:audit && npm run catalog:portable:check && node scripts/sync-public-catalog.mjs",
    "official:check": "python scripts/collect_official_product_data.py --check",
    "official:batch": "python scripts/collect_official_product_data.py",
    "official:all": "python scripts/collect_official_product_data.py --start 0 --limit 776",
    "official:materialize": "python scripts/materialize_official_product_data.py && npm run catalog:sync",
    "official:review": "python scripts/export_official_review_queue.py",
    "health:enrich": "python scripts/health_enrichment.py",
    "health:enrich:resume": "python scripts/health_enrichment.py --resume",
    "health:audit": "python scripts/audit_health_enrichment.py etc/health-enrichment/enrichment-queue.original.json etc/health-enrichment/enrichment-checkpoint.json",
    "deploy:private": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy_private_catalog.ps1",
    "deploy:public": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy_private_catalog.ps1 -Production",
    "kpic:images": "python scripts/collect_kpic_images.py",
    "images:secondary": "python scripts/collect_secondary_images.py --materialize",
    "images:secondary:merge": "python scripts/merge_secondary_images.py && npm run catalog:sync",
    "images:naver": "python scripts/collect_naver_images.py",
    "images:audit": "python scripts/audit_catalog_images.py",
    "kpic:details:merge": "python scripts/merge_kpic_details.py && npm run catalog:sync",
    "predev": "node scripts/catalog-sync-if-changed.mjs",
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/catalog-sync-if-changed.mjs",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:local": "cross-env CATALOG_LOCAL_BUILD=1 npm run build",
    "build:static": "cross-env CATALOG_PUBLIC_BUILD=1 next build",
    "vercel-build": "npm run prebuild && npm run build:static",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit --incremental false",
    "test:unit": "node --experimental-strip-types --test tests/catalog-utils.test.ts && python -m unittest tests.test_official_data tests.test_kpic_images tests.test_kpic_details_part3 tests.test_secondary_images tests.test_naver_images tests.test_merge_kpic_details tests.test_merge_secondary_images tests.test_image_research tests.test_catalog_text_corrections tests.test_catalog_text_normalization tests.test_normalize_catalog_content tests.test_catalog_text_audit tests.test_portable_catalog -v",
    "test": "npm run typecheck && npm run test:unit && cross-env CATALOG_LOCAL_BUILD=1 node scripts/run_local_build_check.mjs && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "overrides": {
    "postcss": "8.5.14"
  }
}
