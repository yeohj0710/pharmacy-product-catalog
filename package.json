{
  "name": "pharmacy-product-catalog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/check-publication-gate.mjs",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:local": "cross-env CATALOG_LOCAL_BUILD=1 npm run build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "cross-env CATALOG_LOCAL_BUILD=1 npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "overrides": {
    "postcss": "8.5.14"
  }
}
