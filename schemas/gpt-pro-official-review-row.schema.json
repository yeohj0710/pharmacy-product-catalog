{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/gpt-pro-official-review-row.schema.json",
  "title": "GPT Pro 공식 제품 검수 CSV 행",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "batch_no",
    "source_order",
    "catalog_product_id",
    "catalog_name",
    "lookup_status",
    "match_status",
    "official_product_key",
    "official_domain",
    "official_item_seq",
    "official_name",
    "official_dataset_id",
    "official_source_url",
    "official_ingredients_json",
    "official_images_json",
    "match_score",
    "match_reason",
    "conflict_reasons_json",
    "reviewer",
    "reviewed_at"
  ],
  "properties": {
    "batch_no": { "type": "string", "pattern": "^[0-9]+$" },
    "source_order": { "type": "string", "pattern": "^[0-9]+$" },
    "catalog_product_id": { "type": "string", "minLength": 1 },
    "catalog_name": { "type": "string", "minLength": 1 },
    "catalog_capacity": { "type": "string" },
    "catalog_category": { "type": "string" },
    "catalog_price": { "type": "string" },
    "lookup_status": {
      "enum": ["pending", "found", "not_found", "not_applicable", "blocked", "error"]
    },
    "match_status": {
      "enum": [
        "pending",
        "confirmed",
        "review_required",
        "not_found",
        "not_applicable",
        "blocked_missing_key",
        "error"
      ]
    },
    "official_product_key": { "type": "string" },
    "official_domain": {
      "enum": ["", "drug", "quasi_drug", "supplement", "cosmetic", "medical_device", "food"]
    },
    "official_item_seq": { "type": "string" },
    "official_name": { "type": "string" },
    "official_manufacturer": { "type": "string" },
    "official_dosage_form": { "type": "string" },
    "official_pack_unit": { "type": "string" },
    "official_barcode": { "type": "string" },
    "official_dataset_id": { "type": "string", "pattern": "^[0-9]*$" },
    "official_source_url": { "type": "string", "pattern": "^(|https://)" },
    "official_efficacy": { "type": "string" },
    "official_dosage": { "type": "string" },
    "official_precautions": { "type": "string" },
    "official_ingredients_json": { "type": "string" },
    "official_images_json": { "type": "string" },
    "match_score": { "type": "string", "pattern": "^(|[0-9]+(?:\\.[0-9]+)?)$" },
    "match_reason": { "type": "string" },
    "conflict_reasons_json": { "type": "string" },
    "reviewer": { "type": "string" },
    "reviewed_at": { "type": "string" }
  }
}
