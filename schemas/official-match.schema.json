{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/official-match.schema.json",
  "title": "판매 SKU와 공식 제품 매칭 레코드",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_product_id",
    "official_product_key",
    "score",
    "status",
    "score_components",
    "matched_fields",
    "alternatives",
    "decision_source",
    "reviewer",
    "reviewed_at",
    "notes",
    "updated_at"
  ],
  "properties": {
    "catalog_product_id": { "type": "string", "minLength": 1 },
    "official_product_key": { "type": "string" },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "status": {
      "enum": [
        "pending",
        "confirmed",
        "review_required",
        "not_found",
        "not_applicable",
        "blocked_missing_key",
        "error"
      ]
    },
    "score_components": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "matched_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "alternatives": {
      "type": "array",
      "items": { "type": "object" }
    },
    "decision_source": { "type": "string" },
    "reviewer": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "notes": { "type": "string" },
    "updated_at": { "type": "string", "minLength": 1 },
    "source_order": { "type": "integer", "minimum": 1 },
    "source_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "error"],
        "properties": {
          "source": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
